{
    "cSpell.customDictionaries": {
        "project": {
            "name": "project",
            "path": "./.vscode/words.txt",
            "addWords": true,
            "scope": "workspace"
        }
    },
    "cSpell.allowCompoundWords": true,
    "cSpell.overrides": [
        {
            "filename": "package.json",
            "ignoreRegExpList": [
                "\"dependencies\"\\s*:\\s*\\{[^}]*\\}",
                "\"devDependencies\"\\s*:\\s*\\{[^}]*\\}"
            ]
        },
        {
            "filename": "nuxt.config.ts",
            "ignoreRegExpList": ["modules\\s*:\\s*\\[[^\\]]*\\]"]
        }
    ],
    "cSpell.words": ["nuxt"]
}
